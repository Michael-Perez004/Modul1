<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- HEADER BNI -->

    <LinearLayout
        android:orientation="vertical"
        android:background="#F37021"
        android:padding="24dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="BNI Mobile Banking"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="24sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Layanan"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginTop="5dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:padding="12dp">

            <!-- MAP -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardMap"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_margin="6dp"
                android:layout_columnWeight="1"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_menu_compass" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lokasi ATM"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CAMERA -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardCamera"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_margin="6dp"
                android:layout_columnWeight="1"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_menu_camera" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ambil Foto"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- SHARE -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardShare"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_margin="6dp"
                android:layout_columnWeight="1"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_menu_share" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bagikan"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- WEBSITE -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardWebsite"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_margin="6dp"
                android:layout_columnWeight="1"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_menu_view" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Website"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CALL -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardCall"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_margin="6dp"
                android:layout_columnWeight="1"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_menu_call" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hubungi BNI"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- YOUTUBE -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardYoutube"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_margin="6dp"
                android:layout_columnWeight="1"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_media_play" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="YouTube"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- INSTAGRAM -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardInstagram"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_margin="6dp"
                android:layout_columnWeight="1"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_menu_gallery" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Instagram"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- NEWS -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardNews"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_margin="6dp"
                android:layout_columnWeight="1"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_menu_agenda" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Berita"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </GridLayout>

    </ScrollView>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- HEADER -->

    <LinearLayout
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- BACK BUTTON -->

        <ImageView
            android:id="@+id/ivBackForgot"
            android:src="@android:drawable/ic_media_previous"
            android:layout_width="30dp"
            android:layout_height="30dp"/>

        <TextView
            android:text="Forgot Password"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="22sp"
            android:layout_marginStart="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <!-- CARD -->

    <androidx.cardview.widget.CardView
        android:layout_margin="24dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:orientation="vertical"
            android:padding="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="Reset Password"
                android:textStyle="bold"
                android:textSize="24sp"
                android:textColor="@color/text_dark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Masukkan email atau username untuk reset password"
                android:textColor="@color/text_light"
                android:layout_marginTop="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- INPUT -->

            <EditText
                android:id="@+id/etForgotInput"
                android:hint="Email atau Username"
                android:padding="14dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/orange_bni"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- BUTTON -->

            <Button
                android:id="@+id/btnResetPassword"
                android:text="KIRIM RESET PASSWORD"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/orange_bni"
                android:layout_marginTop="24dp"
                android:layout_width="match_parent"
                android:layout_height="55dp"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>
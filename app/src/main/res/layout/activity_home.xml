<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_title"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_subtitle"
            android:textSize="18sp"
            android:textColor="@android:color/white"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="20dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="20dp">

            <EditText
                android:id="@+id/etShareText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Input text"
                android:background="@drawable/bg_input"
                android:padding="12dp" />

            <Button
                android:id="@+id/btnShare"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SHARE TO"
                android:layout_marginTop="10dp" />

            <EditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Input phone number"
                android:inputType="phone"
                android:background="@drawable/bg_input"
                android:padding="12dp"
                android:layout_marginTop="16dp" />

            <Button
                android:id="@+id/btnCall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CALL"
                android:layout_marginTop="10dp" />

            <EditText
                android:id="@+id/etLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Input location"
                android:background="@drawable/bg_input"
                android:padding="12dp"
                android:layout_marginTop="16dp" />

            <Button
                android:id="@+id/btnMaps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="OPEN GOOGLE MAP"
                android:layout_marginTop="10dp" />

            <EditText
                android:id="@+id/etWebsite"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Input Website URL"
                android:background="@drawable/bg_input"
                android:padding="12dp"
                android:layout_marginTop="16dp" />

            <Button
                android:id="@+id/btnWebsite"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="OPEN WEBSITE"
                android:layout_marginTop="10dp" />

            <Button
                android:id="@+id/btnCamera"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="OPEN CAMERA"
                android:layout_marginTop="16dp" />

            <Button
                android:id="@+id/btnGallery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="OPEN GALLERY"
                android:layout_marginTop="12dp" />

            <Button
                android:id="@+id/btnAlarm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="OPEN ALARM"
                android:layout_marginTop="12dp" />

            <Button
                android:id="@+id/btnContacts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="OPEN CONTACTS"
                android:layout_marginTop="12dp" />

            <Button
                android:id="@+id/btnNews"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="OPEN NEWS"
                android:layout_marginTop="12dp" />

            <Button
                android:id="@+id/btnInstagram"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="OPEN INSTAGRAM"
                android:layout_marginTop="12dp" />

            <Button
                android:id="@+id/btnFacebook"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="OPEN FACEBOOK"
                android:layout_marginTop="12dp" />

            <Button
                android:id="@+id/btnYoutube"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="OPEN YOUTUBE"
                android:layout_marginTop="12dp" />

            <Button
                android:id="@+id/btnWhatsapp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="OPEN WHATSAPP"
                android:layout_marginTop="12dp" />

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/logout"
                android:layout_marginTop="18dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/gray_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- TOOLBAR -->

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:background="@color/orange_bni"
        android:elevation="4dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!-- HEADER -->

    <LinearLayout
        android:orientation="vertical"
        android:background="@color/orange_bni"
        android:padding="24dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="BNI Mobile Banking"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="26sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Selamat Datang"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:layout_marginTop="5dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- CARD SALDO -->

        <androidx.cardview.widget.CardView
            android:layout_marginTop="20dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:padding="20dp"
                android:orientation="vertical"
                android:background="@color/white"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Saldo Rekening"
                    android:textColor="@color/text_light"
                    android:textSize="14sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="Rp 12.500.000"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold"
                    android:textSize="32sp"
                    android:layout_marginTop="5dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- QUICK MENU -->

    <GridLayout
        android:columnCount="4"
        android:padding="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- MAPS -->

        <LinearLayout
            android:id="@+id/cardMaps"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1">

            <ImageView
                android:src="@android:drawable/ic_dialog_map"
                android:layout_width="40dp"
                android:layout_height="40dp"/>

            <TextView
                android:text="Maps"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="5dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <!-- CAMERA -->

        <LinearLayout
            android:id="@+id/cardCamera"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1">

            <ImageView
                android:src="@android:drawable/ic_menu_camera"
                android:layout_width="40dp"
                android:layout_height="40dp"/>

            <TextView
                android:text="Camera"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="5dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <!-- WEBSITE -->

        <LinearLayout
            android:id="@+id/cardWebsite"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1">

            <ImageView
                android:src="@android:drawable/ic_menu_view"
                android:layout_width="40dp"
                android:layout_height="40dp"/>

            <TextView
                android:text="Website"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="5dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <!-- WHATSAPP -->

        <LinearLayout
            android:id="@+id/cardWhatsapp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1">

            <ImageView
                android:src="@android:drawable/ic_menu_send"
                android:layout_width="40dp"
                android:layout_height="40dp"/>

            <TextView
                android:text="WhatsApp"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="5dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

    </GridLayout>

    <!-- TITLE -->

    <TextView
        android:text="Riwayat Transaksi"
        android:textStyle="bold"
        android:textSize="20sp"
        android:textColor="@color/text_dark"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- RECYCLERVIEW -->

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:padding="6dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- BOTTOM NAVIGATION -->

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:itemIconTint="@color/orange_bni"
        app:itemTextColor="@color/orange_bni"
        app:menu="@menu/bottom_menu"/>

</LinearLayout>